# Copy this file to .env.github.secrets and fill real values.
# Do NOT commit .env.github.secrets.

# Core Cloud Run deploy settings
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
CLOUD_RUN_SERVICE=facefinder-api
GAR_REPOSITORY=facefinder
CLOUD_RUN_DEPLOY=true

# Auth mode A (recommended): Workload Identity Federation
GCP_WORKLOAD_IDENTITY_PROVIDER=projects/123456789/locations/global/workloadIdentityPools/github/providers/github-provider
GCP_SERVICE_ACCOUNT=github-deployer@your-gcp-project-id.iam.gserviceaccount.com

# Auth mode B (alternative): Service account JSON key
# Leave GCP_WORKLOAD_IDENTITY_PROVIDER/GCP_SERVICE_ACCOUNT empty if using this.
# You can set inline JSON OR point to a file with '@' prefix.
# GCP_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
# GCP_CREDENTIALS_JSON=@C:/keys/facefinder-sa.json
