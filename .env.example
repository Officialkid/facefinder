# ── Frontend (Vercel) ─────────────────────────────────────────────────────────
# Set to your deployed Cloud Run URL.
# Leave unset in production if you use the vercel.json rewrite proxy instead.
NEXT_PUBLIC_API_URL=https://facefinder-api-xxxxx-uc.a.run.app

# ── Local development override ────────────────────────────────────────────────
# Uncomment the line below to point the Next.js dev server at your local backend.
# NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Backend (Cloud Run) ───────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins.
# Example: https://your-app.vercel.app,https://your-custom-domain.com
ALLOWED_ORIGINS=https://your-app.vercel.app

# Temp directory for uploads/datasets (default: /tmp, works fine on Cloud Run)
FACEFINDER_TEMP_ROOT=/tmp

